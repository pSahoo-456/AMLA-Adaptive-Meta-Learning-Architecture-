# AMLA Configuration

## Database Settings
MKB_PATH=data/mkb.db
MODEL_PATH=models/metalearner.pkl

## Meta-Learner Settings
N_ESTIMATORS=100
MAX_DEPTH=10
SIMILARITY_TOP_K=5

## Feature Advisor Settings
CORRELATION_THRESHOLD=0.92
SKEWNESS_THRESHOLD=2.0
MISSING_THRESHOLD=30.0
VARIANCE_THRESHOLD=0.01

## Cross-Validation Settings
DEFAULT_CV_FOLDS=5
LANDMARKER_CV_FOLDS=3

## Algorithm Pool
ALGORITHMS=RandomForest,GradientBoosting,LogisticRegression,SVM,KNN

## API Settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_MB=25

## Streamlit Settings
STREAMLIT_PORT=8501
